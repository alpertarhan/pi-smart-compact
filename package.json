{
  "name": "pi-smart-compact",
  "version": "7.9.1",
  "description": "EESV smart compaction extension for Pi Coding Agent — deterministic extraction, exploration, synthesis, verification with redundancy pruning, project fingerprinting, and damage detection.",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "author": "Alper Tarhan <alpertarhan@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alpertarhan/pi-smart-compact.git"
  },
  "homepage": "https://github.com/alpertarhan/pi-smart-compact#readme",
  "bugs": {
    "url": "https://github.com/alpertarhan/pi-smart-compact/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "pi-coding-agent",
    "pi-smart-compact",
    "smart-compaction",
    "context-compression",
    "eesv",
    "conversation-summarization",
    "llm-context"
  ],
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "rm -rf dist && mkdir dist && bun build ./src/index.ts --outdir ./dist --target bun --external '@earendil-works/*' --external 'typebox' && (bunx tsc --emitDeclarationOnly --outDir dist || true)",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "pi": {
    "extensions": ["./dist/index.js"]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "publishConfig": {
    "access": "public"
  }
}
